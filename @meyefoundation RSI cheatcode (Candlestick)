//@version=5
indicator(title="@meyefoundation RSI cheatcode (Candlestick)", shorttitle="MEYE-RSI-Candle-cheatcode", format=format.price, precision=2, timeframe="", timeframe_gaps=true)

// Moving Average Function
ma(source, length, type) =>
    switch type
        "SMA" => ta.sma(source, length)
        "Bollinger Bands" => ta.sma(source, length)
        "EMA" => ta.ema(source, length)
        "SMMA (RMA)" => ta.rma(source, length)
        "WMA" => ta.wma(source, length)
        "VWMA" => ta.vwma(source, length)

// Inputs
rsiLengthInput = input.int(14, minval=1, title="RSI Length", group="RSI Settings")
rsiSourceInput = input.source(close, "Source", group="RSI Settings")
maTypeInput = input.string("SMA", title="MA Type", options=["SMA", "Bollinger Bands", "EMA", "SMMA (RMA)", "WMA", "VWMA"], group="MA Settings")
maLengthInput = input.int(14, title="MA Length", group="MA Settings")
bbMultInput = input.float(2.0, minval=0.001, maxval=50, title="BB StdDev", group="MA Settings")

// RSI Calculation
up = ta.rma(math.max(ta.change(rsiSourceInput), 0), rsiLengthInput)
down = ta.rma(-math.min(ta.change(rsiSourceInput), 0), rsiLengthInput)
rsi = down == 0 ? 100 : up == 0 ? 0 : 100 - (100 / (1 + up / down))
rsiMA = ma(rsi, maLengthInput, maTypeInput)
isBB = maTypeInput == "Bollinger Bands"

// Simulate OHLC data for RSI and RSI-based MA
rsiOpen = request.security(syminfo.tickerid, timeframe.period, rsi[1])
rsiHigh = math.max(rsi, rsiOpen)
rsiLow = math.min(rsi, rsiOpen)
rsiClose = rsi

rsiMAOpen = request.security(syminfo.tickerid, timeframe.period, rsiMA[1])
rsiMAHigh = math.max(rsiMA, rsiMAOpen)
rsiMALow = math.min(rsiMA, rsiMAOpen)
rsiMAClose = rsiMA

// Plot RSI as Candlesticks
plotcandle(rsiOpen, rsiHigh, rsiLow, rsiClose, title="RSI Candlesticks", color=rsi > 70 ? color.rgb(255, 255, 4) : rsi < 30 ? color.green : color.blue)

// Plot RSI-based MA as Candlesticks
plotcandle(rsiMAOpen, rsiMAHigh, rsiMALow, rsiMAClose, title="RSI MA Candlesticks", color=color.rgb(255, 0, 251))

// RSI Levels
rsiUpperBand = hline(70, "RSI Upper Band", color=#787B86)
hline(50, "RSI Middle Band", color=color.new(#787B86, 50))
rsiLowerBand = hline(30, "RSI Lower Band", color=#375eeb)

// Colored Zones
fill(hline(36, "Red Zone Upper", color=color.red), hline(23, "Red Zone Lower", color=color.red), color=color.new(color.red, 90), title="Red Zone")
fill(hline(50, "Orange Zone Upper", color=color.orange), hline(41, "Orange Zone Lower", color=color.orange), color=color.new(color.orange, 90), title="Orange Zone")
fill(hline(76, "Green Zone Upper", color=color.green), hline(66, "Green Zone Lower", color=color.green), color=color.new(color.green, 90), title="Green Zone")

// Bollinger Bands
bbUpperBand = plot(isBB ? rsiMA + ta.stdev(rsi, maLengthInput) * bbMultInput : na, title="Upper Bollinger Band", color=color.green)
bbLowerBand = plot(isBB ? rsiMA - ta.stdev(rsi, maLengthInput) * bbMultInput : na, title="Lower Bollinger Band", color=color.green)
fill(bbUpperBand, bbLowerBand, color=isBB ? color.new(#11ff19, 0) : na, title="Bollinger Bands Background Fill")

// Calculate RSI change from previous candle
rsi_gain = rsi - rsi[1]

// Detect 50+ point RSI surge
big_rsi_jump = rsi_gain >= 50

// Apply white candle coloring (works alongside original logic)
barcolor(big_rsi_jump ? color.new(color.white, 0) : na)
